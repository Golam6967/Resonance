datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Paper {
  id            BigInt       @id @default(autoincrement())
  title         String
  cloudinaryUrl String       @map("cloudinary_url")
  coreProblem   String?      @map("core_problem")
  solution      String?
  drawbacks     String?
  createdAt     DateTime     @default(now()) @map("created_at")
  chunks        PaperChunk[]

  @@map("papers")
}

model PaperChunk {
  id         BigInt  @id @default(autoincrement())
  paperId    BigInt  @map("paper_id")
  chunkText  String  @map("chunk_text")
  pageNumber Int?    @map("page_number")
  
  // Handled cascading deletions to safely wipe vectors along with parent papers
  paper      Paper   @relation(fields: [paperId], references: [id], onDelete: Cascade)

  @@map("paper_chunks")
}

model ChatSession {
  id          Int           @id @default(autoincrement())
  paperId     Int?          // Nullable! Null means it's a global vault chat context
  userId      Int           @default(1)
  userName    String        @default("Guest Analyst")
  title       String        @default("Global Vault Analysis")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]

  @@index([paperId])
}

model ChatMessage {
  id          Int          @id @default(autoincrement())
  sessionId   Int
  role        String       // "user" or "assistant" (Matching your frontend msg.role mapping!)
  content     String       @db.Text
  createdAt   DateTime     @default(now())
  session     ChatSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}