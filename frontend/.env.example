# ── Anthropic (console.anthropic.com → API Keys) ─────────────────────────────
# Used by: src/lib/api.js → AI Chat
VITE_ANTHROPIC_API_KEY=sk-ant-

# ── Cloudinary (cloudinary.com → Settings → API Keys) ────────────────────────
# Used by: backend PDF upload worker
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_API_SECRET=

# ── PostgreSQL (your connection string) ───────────────────────────────────────
# Used by: FastAPI backend / Prisma ORM
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/nexus_research

# ── OpenAI (platform.openai.com → API Keys) ───────────────────────────────────
# Used by: FastAPI embedding worker (text-embedding-3-large)
OPENAI_API_KEY=sk-proj-

# ── Google AI (aistudio.google.com) ──────────────────────────────────────────
# Used by: FastAPI multimodal diagram analysis (Gemini)
GOOGLE_API_KEY=AIzaSy-
